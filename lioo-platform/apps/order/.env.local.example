# Upstash Redis — cache menu portal + rate limit (/o, /t, /api/customer)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Opsional: TTL cache menu detik (default 300). Rate limit: PORTAL_RATE_LIMIT_PAGE_PER_MIN, PORTAL_RATE_LIMIT_API_PER_MIN

# Database (read-only operations; sama dengan apps lain)
DATABASE_URL=

# Xendit (untuk QRIS customer)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# URL internal
NEXT_PUBLIC_POS_URL=http://localhost:3003
NEXT_PUBLIC_ORDER_URL=http://localhost:3004
