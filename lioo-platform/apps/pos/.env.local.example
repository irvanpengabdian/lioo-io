# Kinde Auth (buat aplikasi baru "lioo POS" di Kinde dashboard)
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
KINDE_ISSUER_URL=
KINDE_SITE_URL=http://localhost:3003
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3003
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3003/auth-callback

# Database (sama dengan merchant)
DATABASE_URL=
# Supabase: untuk prisma migrate, koneksi langsung (host db.<project>.supabase.co:5432) — dari Dashboard → Database → URI
# Kosongkan jika tidak pakai pooler / Postgres lokal (sync script akan samakan dengan DATABASE_URL).
# DIRECT_URL=

# SSO redirect (untuk error handling)
NEXT_PUBLIC_SSO_URL=http://localhost:3001
NEXT_PUBLIC_MERCHANT_URL=http://localhost:3002
NEXT_PUBLIC_POS_URL=http://localhost:3003

# Dev only — uji POS tanpa login Kinde (npm run dev). Hapus atau jangan set di Vercel.
# POS_DEV_BYPASS=1
# POS_DEV_BYPASS_EMAIL=lioo.io1521@gmail.com
# POS_DEV_BYPASS_LOG=1

# Xendit — untuk membuat QRIS invoice dari POS
XENDIT_SECRET_KEY=
