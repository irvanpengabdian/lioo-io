{
  "name": "lioo-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "db:generate": "npm run db:generate -w @repo/database && turbo run build",
    "db:migrate": "npm run db:migrate -w @repo/database",
    "db:migrate:deploy": "npm run db:migrate:deploy -w @repo/database",
    "db:migrate:status": "npm run db:migrate:status -w @repo/database",
    "dev": "turbo run dev",
    "dev:apps": "turbo run dev --filter=landing-page --filter=sso --filter=merchant",
    "dev:pos": "turbo run dev --filter=pos",
    "dev:order": "turbo run dev --filter=order",
    "dev:platform": "turbo run dev --filter=merchant --filter=pos --filter=order",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
