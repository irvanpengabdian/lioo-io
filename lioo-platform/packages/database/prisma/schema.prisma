generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH & STAFF
// ─────────────────────────────────────────────

model User {
  id        String   @id // Kinde User ID
  email     String   @unique
  firstName String?
  lastName  String?
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordersCreated Order[] @relation("OrdersCreated")
}

// ─────────────────────────────────────────────
// TENANT (MERCHANT)
// ─────────────────────────────────────────────

model Tenant {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique // used in customer portal URL: /o/[slug]
  planType           PlanType            @default(SEED)
  walletBalance      Float               @default(0)
  description        String?
  logoUrl            String?
  contactNumber      String?
  merchantCategory   String?
  address            String?
  selfServiceTheme   String?             // JSON-stringified theme token overrides for customer portal
  // Staff seat quota (enforced at invite/assign time)
  maxStaffSeats      Int                 @default(1) // plan default: SEED=1, SPROUT=2, BLOOM=5
  purchasedExtraSeats Int               @default(0) // add-on seats via Xendit invoice

  users              User[]
  walletTransactions WalletTransaction[]
  categories         Category[]
  products           Product[]
  orders             Order[]
  tables             Table[]
  customers          Customer[]
  staffInvites       StaffInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// STAFF INVITE
// Owner membuat invite link; staff membuka link → login Kinde → auto-linked ke tenant.
// ─────────────────────────────────────────────

model StaffInvite {
  id        String           @id @default(cuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String           // alamat email yang diundang
  role      Role             @default(STAFF)
  token     String           @unique @default(cuid()) // embedded di invite URL
  status    InviteStatus     @default(PENDING)
  expiresAt DateTime         // 7 hari dari createdAt
  acceptedByUserId String?   // User.id yang menerima invite

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([token])
  @@index([email])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ─────────────────────────────────────────────
// TABLE (DINE-IN QR)
// Each physical table gets a unique qrToken embedded in the QR code.
// The token maps server-side → tenantId + tableId (never trust client-sent tenantId).
// ─────────────────────────────────────────────

model Table {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label    String  // "Meja 1", "Rooftop - 3", "Bar", etc.
  qrToken  String  @unique @default(cuid()) // secret token embedded in QR URL
  isActive Boolean @default(true)

  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, label]) // label must be unique per outlet
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// CUSTOMER (self-service portal)
// Registered customer: phone+name set, isGuest = false.
// Anonymous/guest: phone = null, isGuest = true, guestToken used to link browser session.
// ─────────────────────────────────────────────

model Customer {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone      String?
  name       String?
  isGuest    Boolean  @default(false)
  guestToken String?  @unique // browser-side session token (httpOnly cookie value)

  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, phone]) // registered phone must be unique per outlet
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// MENU CATALOG
// ─────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  icon      String?
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, name])
}

model Product {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])
  name            String
  description     String?
  price           Float
  promoPrice      Float?
  promoValidUntil DateTime?
  imageUrl        String?
  isAvailable     Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orderItems     OrderItem[]
  modifierGroups ModifierGroup[]

  @@index([tenantId, categoryId])
}

model ModifierGroup {
  id         String     @id @default(cuid())
  productId  String
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String     // e.g., "Sugar Level", "Size", "Ice Level"
  isRequired Boolean    @default(false)
  minSelect  Int        @default(0)
  maxSelect  Int        @default(1)
  modifiers  Modifier[]
}

model Modifier {
  id              String        @id @default(cuid())
  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  name            String        // e.g., "Less Sugar", "Large"
  price           Float         @default(0)
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderNumber String      // "ORD-20240327-0001" — unique per tenant, see @@unique below

  // Source & context
  source      OrderSource @default(CASHIER)
  orderType   OrderType   @default(DINE_IN)
  guestCount  Int         @default(1)

  // Table (dine-in)
  tableId     String?
  table       Table?      @relation(fields: [tableId], references: [id])
  tableNumber String?     // snapshot label at order time (in case table is renamed/deleted)

  // Customer (self-service portal)
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  guestSessionId String?   // anonymous session ID (cookie value) if no Customer record

  customerName  String?
  customerPhone String?

  // Status
  status        OrderStatus        @default(PENDING)
  paymentStatus OrderPaymentStatus @default(UNPAID)

  // Financials
  subtotal      Float @default(0)
  taxTotal      Float @default(0)
  discountTotal Float @default(0)
  grandTotal    Float @default(0)

  // Payment
  paymentMethod    String? // cash, qris
  paymentReference String? // Xendit invoice ID, etc.

  // Public code for "pay at counter" QR shown to customer
  publicOrderCode  String? @unique // short human-readable + QR embeddable

  // Offline-first sync support
  offlineId  String?   // locally-generated UUID set by POS before sync
  syncedAt   DateTime? // when offline order was successfully synced
  deviceId   String?   // terminal/device identifier

  // Staff
  createdById String?
  createdBy   User?   @relation("OrdersCreated", fields: [createdById], references: [id])

  orderItems OrderItem[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@unique([tenantId, orderNumber])
  // offlineId uniqueness per tenant is enforced in application (partial unique
  // on non-null offlineId requires a raw migration — see ADR-001)
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, offlineId]) // fast lookup during sync
  @@index([tenantId, paymentStatus])
  @@index([customerId])
  @@index([tableId])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productName         String          // snapshot at order time
  quantity            Int             @default(1)
  unitPrice           Float
  subtotal            Float

  itemStatus          OrderItemStatus @default(PENDING)
  specialInstructions String?
  selectedModifiers   Json?           // [{ id, name, price }]
  sortOrder           Int             @default(0)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// WALLET & BILLING
// ─────────────────────────────────────────────

model WalletTransaction {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  amount      Float
  type        TransactionType
  description String?
  status      TransactionStatus @default(COMPLETED)
  xenditId    String?           @unique
  createdAt   DateTime          @default(now())
}

// ─────────────────────────────────────────────
// CONTENT
// ─────────────────────────────────────────────

model LegalDocument {
  id        String       @id @default(cuid())
  type      DocumentType @unique
  content   String       @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String
  readTime    Int
  content     String   @db.Text
  excerpt     String   @db.Text
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  OWNER
  MANAGER
  STAFF    // kasir
  KITCHEN  // dapur — aktif di plan BLOOM
  FINANCE  // akun keuangan — aktif di plan BLOOM
}

enum PlanType {
  SEED    // 1 staff seat
  SPROUT  // 2 staff seats
  BLOOM   // 5 staff seats + role kitchen & finance
  FOREST  // custom / enterprise
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum OrderSource {
  CASHIER      // dari terminal kasir
  CUSTOMER_APP // self-service portal (QR meja / takeaway)
  ONLINE       // future: delivery platform / marketplace
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING    // dibuat, belum dikonfirmasi dapur
  CONFIRMED  // kasir/sistem konfirmasi
  PREPARING  // dapur sedang menyiapkan
  READY      // siap diambil/disajikan
  SERVED     // sudah dihidangkan
  COMPLETED  // selesai
  CANCELLED
}

enum OrderPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  FAILED
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum DocumentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  ABOUT_US
}
